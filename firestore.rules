rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper check: Is user signed in?
    function isSignedIn() {
      return request.auth != null;
    }

    // Allow read/write access to all collections for authenticated users (admins, agronomists, farmers)
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
